{
  "name": "tailwindcss-default-admin-template",
  "version": "1.0.0",
  "description": "Default dashboard layout with vertical sidebar navigation",
  "main": "index.html",
  "scripts": {
    "build": "gulp buildAssets",
    "build:css": "gulp buildCss",
    "build:js": "gulp copyJS",
    "build:libs": "gulp copyLibs",
    "build:assets": "gulp buildAssets",
    "build:prod": "gulp buildProd",
    "watch": "gulp watchCSS",
    "serve": "npx http-server . -p 8080 -o",
    "dev": "pnpm run watch & pnpm run serve"
  },
  "keywords": [
    "tailwindcss",
    "css",
    "javascript",
    "production",
    "flyonui",
    "dashboard-default"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "apexcharts": "4.7.0",
    "clipboard": "2.0.11",
    "datatables.net": "2.3.3",
    "datatables.net-buttons": "3.2.4",
    "datatables.net-fixedcolumns": "5.0.4",
    "datatables.net-fixedheader": "4.0.3",
    "dropzone": "6.0.0-beta.2",
    "flatpickr": "4.6.13",
    "flyonui": "2.4.0",
    "jquery": "3.7.1",
    "jszip": "3.10.1",
    "lodash": "4.17.23",
    "nouislider": "15.8.1",
    "pdfmake": "0.2.20"
  },
  "devDependencies": {
    "@iconify-json/tabler": "1.2.22",
    "@iconify/json": "2.2.379",
    "@iconify/tailwind4": "1.0.6",
    "@tailwindcss/cli": "4.1.12",
    "clean-css-cli": "5.6.3",
    "fs-extra": "11.3.1",
    "gulp": "4.0.2",
    "http-server": "14.1.1",
    "prettier": "3.5.3",
    "prettier-plugin-tailwindcss": "0.6.14",
    "tailwindcss": "4.1.12",
    "terser": "5.43.1"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "gulp-environment": {
    "environments": [
      {
        "name": "development",
        "aliases": [
          "dev"
        ]
      },
      {
        "name": "production",
        "aliases": [
          "prod"
        ]
      }
    ],
    "default": "development"
  }
}